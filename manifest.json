{
  "name": "省略変換器",
  "description": "日本語を簡潔に書き換える拡張機能。JSON5ルールとkuromoji.jsによる形態素解析を使用。",
  "version": "1.3",
  "manifest_version": 3,
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/json5.min.js",
        "lib/kuromoji.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "transform-bundles.json5",
        "transforms/**",
        "dict/**"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
