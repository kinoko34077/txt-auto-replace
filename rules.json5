// rules.json5
// JSON5なのでコメント可。
// priority が高い順に適用されます。
// conditions.prev / conditions.next には kuromoji の token情報を指定できます。
[
  {
    // 動詞の連体形 + こと → ヿ
    // 例: 書くこと → 書くヿ
    from: "こと",
    to: "ヿ",
    type: "literal",
    priority: 100,
  },
  // ① 面倒ごと系
  {
    from: "ごと",
    to: "事",
    priority: 900,
    conditions: {
      prev: [
        {
          pos_detail_1: "形容動詞語幹"
        }
      ]
    }
  },
  // ② 時ごと系
  {
    from: "ごと",
    to: "毎",
    priority: 800,
    conditions: {
      prev: [
        {
          pos: "名詞",
          pos_detail_1: "一般"
        }
      ]
    }
  },
  {
    // 指示語「それ」→「其」
    from: "それ",
    to: "其",
    type: "literal",
    priority: 90
  },
  {
    from: "その",
    to: "其",
    type: "literal",
    priority: 90
  },
  {
    from: "この",
    to: "此",
    type: "literal",
    priority: 90
  },
  {
    from: "やっぱり",
    to: "矢ッ張",
    type: "literal",
    priority: 85
  },
  {
    from: "分かる",
    to: "分る",
    type: "verb",
    priority: 80
  },
  {
    from: "分かっ",
    to: "分っ",
    type: "verb",
    priority: 80
  },
  {
    from: "悩み",
    to: "悩",
    type: "renyou",
    priority: 75
  },
  {
    from: "書き出す",
    to: "書出す",
    type: "compound",
    priority: 70
  },
  {
    from: "当たる",
    to: "当る",
    type: "verb",
    priority: 65
  },
  {
    from: "、",
    to: "､",
    type: "symbol",
    priority: 10
  },
  {
    from: "。",
    to: "｡",
    type: "symbol",
    priority: 10
  }
]