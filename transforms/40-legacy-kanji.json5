// transforms/40-legacy-kanji.json5
// 旧字変換専用バンドル。
// 基本は単漢字単位または固定熟語単位で管理し、
// 誤爆しやすいものだけ条件付きルールや sequence に逃がす。
// 現段階では箱だけを分離し、個別ルールは未投入。
{
  id: "legacy-kanji",
  label: "旧字変換",
  kind: "dictionary-rules",
  phrase_rules: [
    // 熟語単位の例外や優先語彙をここへ追加する。
    // 例:
    // {
    //   from: "総合",
    //   to: "綜合",
    //   priority: 80,
    // },
  ],
  character_map_priority: 10,
  character_map: {
    // 単漢字単位の旧字変換をここへ追加する。
    // 例:
    // "両": "兩",
    // "乗": "乘",
  },
}
